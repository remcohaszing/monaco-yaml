{
  "include": ["src/**/*.ts"],
  "exclude": [],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "module": "nodenext",
    "rootDir": "src",
    "outDir": ".",
    "skipLibCheck": true,
    "stripInternal": true
  }
}
